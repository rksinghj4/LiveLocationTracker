<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose owns the look at runtime via MaterialTheme. This base style only
         supplies a sensible splash/launch appearance and edge-to-edge defaults. -->
    <style name="Theme.LiveLocationTracker" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>